pub Counter {
    pri count: Int = 0
        .getter
        .setter
    
    pub get(): Int {
        return this.count
    }
    
    pub increment() {
        this.count += 1
    }
}

pub main(): Int {
    c: Counter = Counter()
    print("Initial: " + c.count)
    
    // 测试 setter
    c.count = 10
    print("After set to 10: " + c.count)
    
    // 测试方法修改
    c.increment()
    print("After increment: " + c.count)
    
    return 0
}