pub testReturn(): R<Int, Str> {
    return Ok(100)
}

pub testErr(): R<Int, Str> {
    return Err("error")
}

pub main(): Int {
    print("=== 测试箭头匹配返回值 ===")
    
    // 测试1: Ok 返回 Block，Err 返回表达式
    result1: R<Int, Str> = testReturn()
    x: Int = result1 -> {
        Ok { 42 }      // Block: 返回 42
        Err = 0        // 表达式: 返回 0
    }
    print("x (Ok case, Block): " + x)  // 应该是 null
    
    // 测试2: Err 匹配
    result2: R<Int, Str> = testErr()
    y: Int = result2 -> {
        Ok { 42 }
        Err = 0
    }
    print("y (Err case, expr): " + y)  // 应该是 0
    
    // 测试3: 两个分支都返回表达式
    result3: R<Int, Str> = testReturn()
    z: Int = result3 -> {
        Ok = 100
        Err = 0
    }
    print("z (Ok = expr): " + z)  // 应该是 100
    
    // 测试4: 使用返回值
    value: Int = testReturn() -> {
        Ok = it * 2
        Err = 0
    }
    print("value (it * 2): " + value)  // 应该是 200
    
    return 0
}