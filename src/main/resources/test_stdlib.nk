pub mathAbs(n: Int): Int {
    if (n < 0) return -n
    return n
}

pub mathMax(a: Int, b: Int): Int {
    if (a > b) return a
    return b
}

pub mathMin(a: Int, b: Int): Int {
    if (a < b) return a
    return b
}

pub mathPow(base: Int, exp: Int): Int {
    result: Int = 1
    i: Int = 0
    loop {
        if (i >= exp) break
        result = result * base
        i += 1
    }
    return result
}

pub assertTrue(value: Bool, msg: Str) {
    if (!value) {
        panic("Assertion failed: " + msg)
    }
}

pub assertEq(actual: Any, expected: Any, msg: Str) {
    if (actual != expected) {
        panic("Assertion failed: " + msg + " - Expected " + expected + ", got " + actual)
    }
}

pub panic(msg: Str): Any {
    throw(msg)
}

pub testMath() {
    print("Testing Math library...")
    assertEq(mathAbs(-10), 10, "abs(-10)")
    assertEq(mathAbs(10), 10, "abs(10)")
    assertEq(mathMax(5, 3), 5, "max(5, 3)")
    assertEq(mathMin(5, 3), 3, "min(5, 3)")
    assertEq(mathPow(2, 10), 1024, "pow(2, 10)")
    print("Math tests passed!")
}

pub Counter {
    pri count: Int = 0
        .getter
    pri step: Int = 1
        .getter
    
    pub setup(step: Int) {
        this.step = step
    }
    
    pub increment(): Int {
        this.count += this.step
        return this.count
    }
    
    pub decrement(): Int {
        this.count -= this.step
        return this.count
    }
    
    pub reset() {
        this.count = 0
    }
}

pub testCounter() {
    print("Testing Counter library...")
    c: Counter = Counter()
    c.setup(5)
    assertEq(c.count, 0, "initial count")
    c.increment()
    assertEq(c.count, 5, "after increment")
    c.increment()
    assertEq(c.count, 10, "after second increment")
    c.decrement()
    assertEq(c.count, 5, "after decrement")
    c.reset()
    assertEq(c.count, 0, "after reset")
    print("Counter tests passed!")
}

pub Stack {
    pri data: List
    
    pub setup() {
        this.data = List()
    }
    
    pub push(item: Any) {
        this.data.add(item)
    }
    
    pub pop(): R<Any, Str> {
        if (this.data.size == 0) {
            return Err("Stack is empty")
        }
        item: Any = this.data[this.data.size - 1]
        return Ok(item)
    }
    
    pub peek(): R<Any, Str> {
        if (this.data.size == 0) {
            return Err("Stack is empty")
        }
        return Ok(this.data[this.data.size - 1])
    }
    
    pub isEmpty(): Bool {
        return this.data.size == 0
    }
    
    pub size(): Int {
        return this.data.size
    }
}

pub testStack() {
    print("Testing Stack library...")
    s: Stack = Stack()
    s.setup()
    assertTrue(s.isEmpty(), "stack is initially empty")
    s.push(10)
    s.push(20)
    s.push(30)
    assertEq(s.size(), 3, "stack size after pushes")
    top: R<Any, Str> = s.peek()
    top -> {
        Ok = assertEq(it, 30, "peek returns top")
        Err = panic("peek failed")
    }
    popResult: R<Any, Str> = s.pop()
    popResult -> {
        Ok = assertEq(it, 30, "pop returns top")
        Err = panic("pop failed")
    }
    assertEq(s.size(), 3, "stack size unchanged after pop")
    print("Stack tests passed!")
}

pub Queue {
    pri data: List
    
    pub setup() {
        this.data = List()
    }
    
    pub enqueue(item: Any) {
        this.data.add(item)
    }
    
    pub dequeue(): R<Any, Str> {
        if (this.data.size == 0) {
            return Err("Queue is empty")
        }
        item: Any = this.data[0]
        return Ok(item)
    }
    
    pub peek(): R<Any, Str> {
        if (this.data.size == 0) {
            return Err("Queue is empty")
        }
        return Ok(this.data[0])
    }
    
    pub isEmpty(): Bool {
        return this.data.size == 0
    }
    
    pub size(): Int {
        return this.data.size
    }
}

pub testQueue() {
    print("Testing Queue library...")
    q: Queue = Queue()
    q.setup()
    assertTrue(q.isEmpty(), "queue is initially empty")
    q.enqueue("first")
    q.enqueue("second")
    q.enqueue("third")
    assertEq(q.size(), 3, "queue size after enqueues")
    front: R<Any, Str> = q.peek()
    front -> {
        Ok = assertEq(it, "first", "peek returns front")
        Err = panic("peek failed")
    }
    deq: R<Any, Str> = q.dequeue()
    deq -> {
        Ok = assertEq(it, "first", "dequeue returns front")
        Err = panic("dequeue failed")
    }
    assertEq(q.size(), 3, "queue size unchanged after dequeue")
    print("Queue tests passed!")
}

pub unwrapOr(result: R, default: Any): Any {
    return result -> {
        Ok = it
        Err = default
    }
}

pub testResult() {
    print("Testing Result library...")
    okVal: R<Int, Str> = Ok(42)
    errVal: R<Int, Str> = Err("error")
    assertEq(unwrapOr(okVal, 0), 42, "unwrapOr returns Ok value")
    assertEq(unwrapOr(errVal, 0), 0, "unwrapOr returns default for Err")
    print("Result tests passed!")
}

pub main(): Int {
    print("=== Running Bootstrap Library Tests ===")
    print("")
    
    testMath()
    print("")
    testCounter()
    print("")
    testStack()
    print("")
    testQueue()
    print("")
    testResult()
    
    print("")
    print("=== All Bootstrap Library Tests Passed! ===")
    return 0
}
