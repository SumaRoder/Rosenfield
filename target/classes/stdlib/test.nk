pub Assert {
    pub assertTrue(value: Bool, msg?: Str = "Expected true") {
        if (!value) {
            panic("Assertion failed: " + msg)
        }
    }
    
    pub assertFalse(value: Bool, msg?: Str = "Expected false") {
        if (value) {
            panic("Assertion failed: " + msg)
        }
    }
    
    pub assertEq(actual: Any, expected: Any, msg?: Str = "Values not equal") {
        if (actual != expected) {
            panic("Assertion failed: " + msg + " - Expected " + expected + ", got " + actual)
        }
    }
    
    pub assertNe(actual: Any, expected: Any, msg?: Str = "Values should not be equal") {
        if (actual == expected) {
            panic("Assertion failed: " + msg + " - Values are equal: " + actual)
        }
    }
    
    pub assertGt(a: Int, b: Int, msg?: Str = "Value not greater") {
        if (!(a > b)) {
            panic("Assertion failed: " + msg + " - " + a + " is not > " + b)
        }
    }
    
    pub assertLt(a: Int, b: Int, msg?: Str = "Value not less") {
        if (!(a < b)) {
            panic("Assertion failed: " + msg + " - " + a + " is not < " + b)
        }
    }
    
    pub assertOk(result: R, msg?: Str = "Expected Ok") {
        result -> {
            Ok {}
            Err = panic("Assertion failed: " + msg + " - Got Err: " + it)
        }
    }
    
    pub assertErr(result: R, msg?: Str = "Expected Err") {
        result -> {
            Ok = panic("Assertion failed: " + msg + " - Got Ok: " + it)
            Err {}
        }
    }
}

pub TestRunner {
    pri passed: Int = 0
        .getter
    pri failed: Int = 0
        .getter
    
    pub run(name: Str, fn: Function) {
        print("Running: " + name + " ... ")
        result: R<Any, Str> = runTest(fn)
        result -> {
            Ok {
                print("PASS")
                this.passed += 1
            }
            Err = {
                print("FAIL: " + it)
                this.failed += 1
            }
        }
    }
    
    pub summary() {
        print("")
        print("=========================")
        print("Tests passed: " + this.passed)
        print("Tests failed: " + this.failed)
        total: Int = this.passed + this.failed
        print("Total: " + total)
        if (this.failed == 0) {
            print("All tests passed!")
        }
    }
    
    pri runTest(fn: Function): R<Any, Str> {
        try {
            fn()
            return Ok(null)
        } catch (e: Str) {
            return Err(e)
        }
    }
}

pub panic(msg: Str) {
    throw(msg)
}
