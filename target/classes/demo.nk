pub Person {
    pri name: Str
        .getter
    pri age: Int = 0
        .getter
    
    pub init(name: Str, age: Int) {
        this.name = name
        this.age = age
    }
    
    pub greet(): Str {
        return "Hello, I'm " + this.name + ", " + this.age + " years old"
    }
    
    pub haveBirthday() {
        this.age += 1
    }
}

pub divide(a: Int, b: Int): R<Int, Str> {
    if (b == 0) {
        return Err("Cannot divide by zero")
    }
    return Ok(a / b)
}

pub main(): Int {
    p: Person = Person("Alice", 25)
    print(p.greet())
    
    p.haveBirthday()
    print("After birthday: " + p.age)
    
    result: R<Int, Str> = divide(10, 2)
    result -> {
        Ok {
            print("10 / 2 = " + it)
        }
        Err = print("Error: " + it)
    }
    
    result2: R<Int, Str> = divide(10, 0)
    result2 -> {
        Ok {
            print("Result: " + it)
        }
        Err = print("Caught error: " + it)
    }
    
    return 0
}
